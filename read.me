<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HTML (1–4-dars) — Test</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #0f172a;
            color: #f8fafc;
            margin: 0;
            padding: 20px;
        }
        .quiz-container {
            max-width: 650px;
            margin: 0 auto;
            background-color: #1e293b;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
        }
        h1 {
            text-align: center;
            color: #38bdf8;
            margin-bottom: 30px;
            font-size: 24px;
        }
        .question-block {
            background-color: #334155;
            padding: 15px 20px;
            border-radius: 8px;
            margin-bottom: 20px;
        }
        .question-title {
            font-weight: 600;
            margin-bottom: 12px;
            color: #f1f5f9;
        }
        .options label {
            display: block;
            margin: 8px 0;
            cursor: pointer;
            padding: 6px;
            border-radius: 4px;
            transition: background 0.2s;
        }
        .options label:hover {
            background-color: #475569;
        }
        .options input {
            margin-right: 10px;
        }
        .btn-submit {
            display: block;
            width: 100%;
            background-color: #38bdf8;
            color: #0f172a;
            border: none;
            padding: 12px;
            font-size: 16px;
            font-weight: bold;
            border-radius: 6px;
            cursor: pointer;
            margin-top: 30px;
            transition: background 0.2s;
        }
        .btn-submit:hover {
            background-color: #0ea5e9;
        }
        #result {
            margin-top: 25px;
            padding: 15px;
            border-radius: 6px;
            text-align: center;
            font-size: 18px;
            font-weight: bold;
            display: none;
        }
        .success {
            background-color: #065f46;
            color: #34d399;
        }
    </style>
</head>
<body>

<div class="quiz-container">
    <h1>HTML (1–4-dars) bo'yicha Bilimni Tekshirish</h1>
    
    <form id="quizForm">
        <!-- 1-savol -->
        <div class="question-block">
            <div class="question-title">1. Giperhavola yaratish uchun qaysi teg ishlatiladi?</div>
            <div class="options">
                <label><input type="radio" name="q1" value="A"> A) &lt;img&gt;</label>
                <label><input type="radio" name="q1" value="B"> B) &lt;a&gt;</label>
                <label><input type="radio" name="q1" value="C"> C) &lt;link&gt;</label>
                <label><input type="radio" name="q1" value="D"> D) &lt;href&gt;</label>
            </div>
        </div>

        <!-- 2-savol -->
        <div class="question-block">
            <div class="question-title">2. &lt;a&gt; tegidagi manzil ko'rsatiladigan atribut qaysi?</div>
            <div class="options">
                <label><input type="radio" name="q2" value="A"> A) src</label>
                <label><input type="radio" name="q2" value="B"> B) href</label>
                <label><input type="radio" name="q2" value="C"> C) alt</label>
                <label><input type="radio" name="q2" value="D"> D) link</label>
            </div>
        </div>

        <!-- 3-savol -->
        <div class="question-block">
            <div class="question-title">3. Rasm qo'shish uchun qaysi teg ishlatiladi?</div>
            <div class="options">
                <label><input type="radio" name="q3" value="A"> A) &lt;picture&gt;</label>
                <label><input type="radio" name="q3" value="B"> B) &lt;image&gt;</label>
                <label><input type="radio" name="q3" value="C"> C) &lt;img&gt;</label>
                <label><input type="radio" name="q3" value="D"> D) &lt;src&gt;</label>
            </div>
        </div>

        <!-- 4-savol -->
        <div class="question-block">
            <div class="question-title">4. &lt;img&gt; tegida rasm manzili qaysi atribut orqali beriladi?</div>
            <div class="options">
                <label><input type="radio" name="q4" value="A"> A) href</label>
                <label><input type="radio" name="q4" value="B"> B) src</label>
                <label><input type="radio" name="q4" value="C"> C) alt</label>
                <label><input type="radio" name="q4" value="D"> D) path</label>
            </div>
        </div>

        <!-- 5-savol -->
        <div class="question-block">
            <div class="question-title">5. Rasm yuklanmasa chiqadigan matn qaysi atribut orqali yoziladi?</div>
            <div class="options">
                <label><input type="radio" name="q5" value="A"> A) title</label>
                <label><input type="radio" name="q5" value="B"> B) name</label>
                <label><input type="radio" name="q5" value="C"> C) alt</label>
                <label><input type="radio" name="q5" value="D"> D) text</label>
            </div>
        </div>

        <!-- 6-savol -->
        <div class="question-block">
            <div class="question-title">6. Matnni ajratib ko'rsatish uchun qaysi teg ishlatiladi?</div>
            <div class="options">
                <label><input type="radio" name="q6" value="A"> A) &lt;strong&gt;</label>
                <label><input type="radio" name="q6" value="B"> B) &lt;mark&gt;</label>
                <label><input type="radio" name="q6" value="C"> C) &lt;b&gt;</label>
                <label><input type="radio" name="q6" value="D"> D) &lt;em&gt;</label>
            </div>
        </div>

        <!-- 7-savol -->
        <div class="question-block">
            <div class="question-title">7. Pastki indeks uchun qaysi teg ishlatiladi?</div>
            <div class="options">
                <label><input type="radio" name="q7" value="A"> A) &lt;sup&gt;</label>
                <label><input type="radio" name="q7" value="B"> B) &lt;sub&gt;</label>
                <label><input type="radio" name="q7" value="C"> C) &lt;small&gt;</label>
                <label><input type="radio" name="q7" value="D"> D) &lt;mark&gt;</label>
            </div>
        </div>

        <!-- 8-savol -->
        <div class="question-block">
            <div class="question-title">8. Yuqori indeks uchun qaysi teg ishlatiladi?</div>
            <div class="options">
                <label><input type="radio" name="q8" value="A"> A) &lt;sub&gt;</label>
                <label><input type="radio" name="q8" value="B"> B) &lt;sup&gt;</label>
                <label><input type="radio" name="q8" value="C"> C) &lt;mark&gt;</label>
                <label><input type="radio" name="q8" value="D"> D) &lt;strong&gt;</label>
            </div>
        </div>

        <!-- 9-savol -->
        <div class="question-block">
            <div class="question-title">9. Tugma yaratish uchun qaysi teg ishlatiladi?</div>
            <div class="options">
                <label><input type="radio" name="q9" value="A"> A) &lt;input&gt;</label>
                <label><input type="radio" name="q9" value="B"> B) &lt;button&gt;</label>
                <label><input type="radio" name="q9" value="C"> C) &lt;submit&gt;</label>
                <label><input type="radio" name="q9" value="D"> D) &lt;click&gt;</label>
            </div>
        </div>

        <!-- 10-savol -->
        <div class="question-block">
            <div class="question-title">10. Foydalanuvchidan ma'lumot kiritish uchun qaysi teg ishlatiladi?</div>
            <div class="options">
                <label><input type="radio" name="q10" value="A"> A) &lt;textarea&gt;</label>
                <label><input type="radio" name="q10" value="B"> B) &lt;button&gt;</label>
                <label><input type="radio" name="q10" value="C"> C) &lt;input&gt;</label>
                <label><input type="radio" name="q10" value="D"> D) &lt;label&gt;</label>
            </div>
        </div>

        <button type="button" class="btn-submit" onclick="checkQuiz()">Natijani Tekshirish</button>
    </form>

    <div id="result" class="success"></div>
</div>

<script>
    function checkQuiz() {
        // To'g'ri javoblar kaliti
        const correctAnswers = {
            q1: 'B',
            q2: 'B',
            q3: 'C',
            q4: 'B',
            q5: 'C',
            q6: 'B',
            q7: 'B',
            q8: 'B',
            q9: 'B',
            q10: 'C'
        };

        let score = 0;
        const form = document.getElementById('quizForm');
        
        // 10 ta savolni aylanib tekshirish
        for (let i = 1; i <= 10; i++) {
            const selector = `input[name="q${i}"]:checked`;
            const checkedOption = form.querySelector(selector);
            
            if (checkedOption && checkedOption.value === correctAnswers[`q${i}`]) {
                score++;
            }
        }

        // Natijani ekranga chiqarish
        const resultDiv = document.getElementById('result');
        resultDiv.style.display = 'block';
        resultDiv.innerHTML = `Siz 10 ta savoldan ${score} tasiga to'g'ri javob berdingiz! (${Math.round(score * 10)}%)`;
        
        // Sahifani natija blokiga yurgizish
        resultDiv.scrollIntoView({ behavior: 'smooth' });
    }
</script>

</body>
</html>
